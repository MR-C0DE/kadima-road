    if (!helper) {
      return res.status(404).json({
        success: false,
        message: 'Helper non trouvé'
      });
    }

    const docIndex = helper.documents.findIndex(doc => doc.type === type);

    if (docIndex === -1) {
      return res.status(404).json({
        success: false,
        message: 'Document non trouvé'
      });
