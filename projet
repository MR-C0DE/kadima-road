              {QUICK_DIAGNOSTICS.map((item, index) => (
                <Animated.View
                  key={item.id}
                  style={[
                    styles.quickDiagnosticItem,
                    selectedQuickDiagnostic === item.id &&
                      styles.quickDiagnosticItemSelected,
                    {
                      opacity: fadeAnim,
                      transform: [
                        {
                          translateX: slideAnim.interpolate({
                            inputRange: [0, 50],
