{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kadima",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kadima.road",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Kadima Road a besoin de votre position pour trouver des helpers près de chez vous.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Kadima Road a besoin de votre position pour les alertes SOS.",
        "CFBundleURLTypes": [{
          "CFBundleURLSchemes": ["kadima"]
        }]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.kadima.road",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "intentFilters": [{
        "action": "VIEW",
        "data": [{
          "scheme": "kadima"
        }],
        "category": ["BROWSABLE", "DEFAULT"]
      }]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Kadima Road a besoin de votre position pour trouver des helpers près de chez vous.",
          "locationWhenInUsePermission": "Kadima Road a besoin de votre position pour les alertes SOS."
        }
      ],
      "expo-mail-composer"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}